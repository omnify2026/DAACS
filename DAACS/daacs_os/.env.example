# ===== DAACS OS Environment Variables =====
# Copy this file to .env and fill in your values

# ----- Database -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=daacs
POSTGRES_USER=daacs
POSTGRES_PASSWORD=generate-a-strong-password

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- ChromaDB -----
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ----- API Server -----
DAACS_ENV=dev
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=1
DAACS_JWT_SECRET=generate-a-strong-random-secret
DAACS_FERNET_SECRET=generate-a-separate-strong-random-secret
# Production: must be explicitly set. Wildcard '*' is forbidden in production.
DAACS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DAACS_ENABLE_HSTS=true

# ----- Auth Security -----
DAACS_AUTH_RATE_WINDOW_SECONDS=300
DAACS_AUTH_LOGIN_MAX_ATTEMPTS=20
DAACS_AUTH_REGISTER_MAX_ATTEMPTS=10
DAACS_AUTH_BYOK_MAX_ATTEMPTS=30
DAACS_RATE_LIMIT_FAIL_CLOSED=false
DAACS_AUTH_COOKIE_NAME=daacs_access_token
DAACS_AUTH_COOKIE_MAX_AGE_SECONDS=604800
DAACS_AUTH_COOKIE_SAMESITE=lax
# Leave empty to auto-detect (production/https => true)
DAACS_AUTH_COOKIE_SECURE=
DAACS_AUTH_COOKIE_PATH=/
DAACS_AUTH_COOKIE_DOMAIN=
# Enable when using cross-site cookies (SameSite=None). Requires X-CSRF-Token header on unsafe methods.
DAACS_CSRF_ENFORCE=false
DAACS_CSRF_COOKIE_NAME=daacs_csrf_token
DAACS_CSRF_HEADER_NAME=x-csrf-token

# ----- Web Frontend (Vite) -----
# For production behind same-domain reverse proxy, leave blank to auto-use current origin.
VITE_API_BASE_URL=http://127.0.0.1:8001
# Optional JSON URL for SkillBundleSummary when not using Tauri (overrides bundled snapshot).
# VITE_SKILL_BUNDLES_URL=https://api.example.com/skills/bundles.json
VITE_UI_ONLY=false

# ----- LLM API Keys -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ----- Smart Model Router / CLI -----
DAILY_SPEND_CAP_USD=1.00
MAX_TURN_LIMIT=10
DEFAULT_MODEL_TIER=standard
# CLI: codex | claude | gemini. For Gemini CLI: DAACS_CODEX_ONLY=false and DAACS_CLI_ONLY_PROVIDER=gemini
DAACS_CLI_ONLY_PROVIDER=codex
# If true, forces Codex. Set false when using DAACS_CLI_ONLY_PROVIDER=gemini (or claude).
DAACS_CODEX_ONLY=true
DAACS_CODEX_MODEL=gpt-5.3-codex
# Optional: path to Gemini CLI (e.g. npm global). Leave empty to resolve from PATH.
# DAACS_GEMINI_CLI_PATH=

# ----- Docker Sandbox -----
SANDBOX_CPU_LIMIT=0.5
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_NETWORK_ENABLED=false
SANDBOX_TIMEOUT_SECONDS=300

# ----- SaaS (Optional) -----
SUPABASE_URL=
SUPABASE_ANON_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Celery -----
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
