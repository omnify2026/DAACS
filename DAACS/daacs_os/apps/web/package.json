{
    "name":  "daacs-web",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "release:preflight":  "node scripts/verify-third-phase-readiness.mjs --preflight",
                    "release:candidate":  "node scripts/verify-third-phase-readiness.mjs --candidate",
                    "sync-skill-bundles":  "node scripts/sync-skill-bundle-summary.mjs",
                    "lint":  "eslint .",
                    "test":  "node --import tsx src/regression/runWebVerification.ts",
                    "smoke":  "playwright test --config=playwright.config.ts --project=chromium",
                    "smoke:chromium":  "playwright test --config=playwright.config.ts --project=chromium",
                    "smoke:headed":  "playwright test --config=playwright.config.ts --project=chromium --headed",
                    "test:regression":  "node --import tsx src/regression/runWebVerification.ts",
                    "start":  "vite preview --host 0.0.0.0 --port 3000",
                    "preview":  "vite preview --host 0.0.0.0 --port 3000",
                    "sync-bundled-prompts":  "node scripts/sync-bundled-prompt-texts.mjs",
                    "sync-skills":  "node scripts/sync-skills.mjs"
                },
    "dependencies":  {
                         "@tauri-apps/plugin-fs": "^2.0.0",
                         "framer-motion":  "^12.34.0",
                         "lucide-react":  "^0.563.0",
                         "react":  "^19.2.0",
                         "react-dom":  "^19.2.0",
                         "wouter":  "^3.9.0",
                         "zustand":  "^5.0.11"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^9.39.1",
                            "@playwright/test":  "^1.59.1",
                            "@tailwindcss/postcss":  "^4.1.18",
                            "@types/node":  "^24.10.1",
                            "@types/react":  "^19.2.7",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react":  "^5.1.1",
                            "autoprefixer":  "^10.4.24",
                            "eslint":  "^9.39.1",
                            "eslint-plugin-react-hooks":  "^7.0.1",
                            "eslint-plugin-react-refresh":  "^0.4.24",
                            "globals":  "^16.5.0",
                            "postcss":  "^8.5.6",
                            "tailwindcss":  "^4.1.18",
                            "tsx":  "^4.21.0",
                            "typescript":  "~5.9.3",
                            "typescript-eslint":  "^8.48.0",
                            "vite":  "^7.3.1",
                            "yaml":  "^2.8.0"
                        }
}
