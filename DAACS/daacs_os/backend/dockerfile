FROM rust:1-bookworm AS builder
WORKDIR /build
COPY . .
RUN cargo build --release -p daacs-auth-api

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates libssl3 && rm -rf /var/lib/apt/lists/*
WORKDIR /app
RUN mkdir -p /app/data
COPY --from=builder /build/target/release/daacs-auth-api /app/daacs-auth-api
ENV DAACS_DATABASE_URL=sqlite:/app/data/daacs.db
ENV DAACS_AUTH_HOST=0.0.0.0
ENV DAACS_AUTH_PORT=8001
EXPOSE 8001
VOLUME /app/data
CMD ["/app/daacs-auth-api"]
